{
  "manifest_version": 3,
  "name": "Amazon Prime All Autoselect & Lowest Price Sorting",
  "version": "2.0.0",
  "description": "Automatically apply Prime filters and sort by lowest price on Amazon. Works on all marketplaces. Privacy-first with no data collection.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.de/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.fr/*",
    "https://www.amazon.it/*",
    "https://www.amazon.es/*",
    "https://www.amazon.ca/*",
    "https://www.amazon.co.jp/*",
    "https://www.amazon.com.au/*",
    "https://www.amazon.com.mx/*",
    "https://www.amazon.com.br/*",
    "https://www.amazon.in/*",
    "https://www.amazon.nl/*",
    "https://www.amazon.se/*",
    "https://www.amazon.pl/*",
    "https://www.amazon.sg/*",
    "https://www.amazon.ae/*",
    "https://www.amazon.tr/*",
    "https://www.amazon.eg/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.de/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.it/*",
        "https://www.amazon.es/*",
        "https://www.amazon.ca/*",
        "https://www.amazon.co.jp/*",
        "https://www.amazon.com.au/*",
        "https://www.amazon.com.mx/*",
        "https://www.amazon.com.br/*",
        "https://www.amazon.in/*",
        "https://www.amazon.nl/*",
        "https://www.amazon.se/*",
        "https://www.amazon.pl/*",
        "https://www.amazon.sg/*",
        "https://www.amazon.ae/*",
        "https://www.amazon.tr/*",
        "https://www.amazon.eg/*"
      ],
      "js": [
        "lib/storage.js",
        "content/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "scripts": ["background/service-worker.js"]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Amazon Prime Sorter Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "amazon-prime-all-autoselect@amazon-prime-sorter.example.com",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "109.0"
    }
  },
  "homepage_url": "https://github.com/amazon-prime-sorter/amazon-prime-all-autoselect",
  "author": "Amazon Prime Sorter Contributors"
}
